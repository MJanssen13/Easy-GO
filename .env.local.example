# Copy this file to `.env.local` and fill with your Supabase project values.
# NEVER commit `.env.local`. These two values are safe to expose to the browser,
# but real access control is enforced by Row Level Security (see supabase/migrations).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only key for admin/seed scripts (NEVER expose to the browser, NEVER commit).
# Optional during app development; only needed for privileged maintenance tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
